# ─── Barsy API ──────────────────────────────────────────────
# Same credentials the bridge uses (basic auth)
BARSY_BASE_URL=https://bm-habits.barsy.bg
BARSY_USER=
BARSY_PASS=
BARSY_BID=1

# ─── Dashboard auth ─────────────────────────────────────────
# Option 1 (preferred): Clerk (free tier at https://dashboard.clerk.com)
# When both keys are set, the dashboard requires Clerk sign-in.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Option 2 (fallback): HTTP Basic Auth — used only when Clerk keys are absent
DASH_USER=admin
DASH_PASS=
